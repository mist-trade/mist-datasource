# 全局
APP_ENV=development          # development 用 mock，production 用真实 SDK
LOG_LEVEL=INFO

# TDX Instance
TDX_HOST=0.0.0.0
TDX_PORT=9001
# TDX SDK 路径 (Windows 生产环境必填)
# 指向包含 tqcenter.py 的目录 (通达信官方 SDK 结构如下):
#   D:/tdx/PYPlugins/
#       TPythClient.dll           ← SDK 会通过 Path(__file__).parents[1] 自动定位
#       user/
#           tqcenter.py           ← TDX_SDK_PATH 指向这个目录
# 例如: TDX_SDK_PATH=D:/tdx/PYPlugins/user
TDX_SDK_PATH=

# QMT Instance
QMT_HOST=0.0.0.0
QMT_PORT=9002
QMT_PATH=/path/to/miniQMT    # QMT 客户端路径
QMT_ACCOUNT_ID=               # QMT 资金账号
# QMT SDK 路径 (Windows 生产环境必填)
# 通常指向 miniQMT 安装目录下的 Lib 文件夹
# 例如: D:/miniQMT/Lib  (目录下应有 xtquant/__init__.py)
QMT_SDK_PATH=

# NestJS 连接
ALLOWED_ORIGINS=http://localhost:8001,http://localhost:8002
