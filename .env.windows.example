# Windows API appliance datasource configuration
#
# Copy this file to .env on the Windows API machine and update absolute paths.
# Do not copy TDX/QMT SDK files into the appliance package; point these paths at
# the existing authorized client installations on the machine.

APP_ENV=production
LOG_LEVEL=INFO

# TDX instance, consumed only by local MistBackend.
TDX_HOST=127.0.0.1
TDX_PORT=9001

# Required for production TDX.
# Expected layout:
#   D:/tdx/PYPlugins/TPythClient.dll
#   D:/tdx/PYPlugins/user/tqcenter.py
TDX_SDK_PATH=D:/tdx/PYPlugins/user

# Optional QMT instance. Leave QMT_SDK_PATH empty to skip QMT service install.
QMT_HOST=127.0.0.1
QMT_PORT=9002
QMT_PATH=D:/miniQMT
QMT_ACCOUNT_ID=
QMT_SDK_PATH=

# AKTools is not part of the first Windows appliance path.
AKTOOLS_HOST=127.0.0.1
AKTOOLS_PORT=8080

# NestJS backend runs on the same Windows machine.
ALLOWED_ORIGINS=http://127.0.0.1:8001
