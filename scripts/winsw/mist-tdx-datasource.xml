<service>
  <id>mist-tdx-datasource</id>
  <name>mist-tdx-datasource</name>
  <description>Mist TDX Python datasource HTTP/WebSocket adapter.</description>

  <workingdirectory>{{PROJECT_DIR}}</workingdirectory>
  <executable>{{DATASOURCE_EXECUTABLE}}</executable>
  <arguments>{{DATASOURCE_ARGUMENTS}}</arguments>

  <env name="APP_ENV" value="production" />
  <env name="TDX_HTTP_URL" value="{{TDX_HTTP_URL}}" />
  <env name="TDX_SDK_PATH" value="{{TDX_SDK_PATH}}" />
  <env name="DATASOURCE_HOST" value="{{DATASOURCE_HOST}}" />
  <env name="DATASOURCE_PORT" value="{{DATASOURCE_PORT}}" />
  <env name="TDX_MINUTE_PERIOD" value="{{TDX_MINUTE_PERIOD}}" />
  <env name="TDX_COLLECT_DELAY_SECONDS" value="{{TDX_COLLECT_DELAY_SECONDS}}" />
  <env name="TDX_RETRY_DELAY_SECONDS" value="{{TDX_RETRY_DELAY_SECONDS}}" />
  <env name="TDX_RECONCILE_INTERVAL_SECONDS" value="{{TDX_RECONCILE_INTERVAL_SECONDS}}" />
  <env name="TDX_MAX_SUBSCRIPTIONS" value="{{TDX_MAX_SUBSCRIPTIONS}}" />
  <env name="TDX_WS_QUEUE_MAX_SIZE" value="{{TDX_WS_QUEUE_MAX_SIZE}}" />

  <startmode>Automatic</startmode>
  <onfailure action="restart" delay="10 sec" />
  <onfailure action="restart" delay="30 sec" />
  <resetfailure>1 hour</resetfailure>

  <logpath>{{LOG_DIR}}</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10485760</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>
</service>
